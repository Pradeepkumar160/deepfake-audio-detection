dataset/real/*.wav
dataset/fake/*.wav
dataset/real/*.mp3
dataset/fake/*.mp3

# Keep dataset folder structure
!dataset/real/.gitkeep
!dataset/fake/.gitkeep

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

